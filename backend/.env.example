# Copy to .env and fill in. The app runs without OPENAI_API_KEY (AI features
# degrade gracefully to "AI disabled").
DATABASE_URL=sqlite+aiosqlite:///./inventory.db
# For Postgres (docker-compose): postgresql+asyncpg://inv:inv@db:5432/inventory
JWT_SECRET=change-me
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SEED_ON_STARTUP=true
CORS_ORIGINS=*
